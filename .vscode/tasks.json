{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Iniciar CodLearn",
      "type": "shell",
      "command": "npm run dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting...",
          "endsPattern": "Ready"
        }
      },
      "runOptions": { "runOn": "folderOpen" },
      "presentation": { "reveal": "always", "panel": "new" }
    }
  ]
}
